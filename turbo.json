{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "PORT",
    "VITE_WS_URL",
    "VITE_DEV_SERVER_URL",
    "T3CODE_LOG_WS_EVENTS",
    "T3CODE_MODE",
    "T3CODE_PORT",
    "T3CODE_NO_BROWSER",
    "T3CODE_STATE_DIR",
    "T3CODE_AUTH_TOKEN",
    "T3CODE_DESKTOP_WS_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "dist-electron/**"]
    },
    "dev": {
      "dependsOn": ["^dev"],
      "cache": false,
      "persistent": false
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
