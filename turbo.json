{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["ELECTRON_RENDERER_PORT"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "dist-electron/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "smoke-test": {
      "dependsOn": ["build"],
      "cache": false,
      "outputs": []
    }
  }
}
